generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Source {
  id           String    @id @default(cuid())
  type         String    // chatgpt_export | claude_code | claude_desktop | claude_export | granola | manual | poke
  name         String
  accountLabel String?   // e.g., "personal@email.com" or "Work"
  status       String    @default("active") // active | error
  config       String    @default("{}") // JSON: paths, settings
  lastSyncAt   DateTime?
  lastFileHash String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  conversations Conversation[]
  memories      Memory[]
  syncRuns      SyncRun[]
}

model Conversation {
  id           String    @id @default(cuid())
  externalId   String
  sourceId     String
  source       Source    @relation(fields: [sourceId], references: [id])
  title        String?
  messageCount Int       @default(0)
  contentHash  String
  createdAt    DateTime  @default(now())
  sourceDate   DateTime?

  memories Memory[]

  @@unique([sourceId, externalId])
  @@index([contentHash])
}

model Memory {
  id             String    @id @default(cuid())
  content        String
  subject        String    @default("user")
  category       String
  confidence     Float
  verbatimQuote  String?
  temporality    String    @default("durable") // durable | current | expired
  sensitive      Boolean   @default(false)
  referenceCount Int       @default(1)
  lastReferencedAt DateTime @default(now())
  manuallyStrong Boolean   @default(false)

  sourceId       String
  source         Source    @relation(fields: [sourceId], references: [id])
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])

  status         String    @default("pending") // pending | active | rejected | archived | deleted
  approvedAt     DateTime?
  archivedAt     DateTime?
  archivedReason String?

  project        String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  reviewItems    ReviewItem[]
  conflictsAsNew Conflict[] @relation("ConflictNew")
  conflictsAsOld Conflict[] @relation("ConflictExisting")
  folders        MemoryFolder[]

  @@index([category])
  @@index([status])
  @@index([sourceId])
}

model Conflict {
  id               String    @id @default(cuid())
  newMemoryId      String
  newMemory        Memory    @relation("ConflictNew", fields: [newMemoryId], references: [id])
  existingMemoryId String
  existingMemory   Memory    @relation("ConflictExisting", fields: [existingMemoryId], references: [id])
  type             String    // contradiction | duplicate | refinement | supersede
  reasoning        String
  suggestedAction  String    // keep_new | keep_existing | merge | keep_both
  mergedContent    String?
  status           String    @default("pending") // pending | resolved | dismissed
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())

  reviewItem ReviewItem?
}

model ReviewItem {
  id         String    @id @default(cuid())
  memoryId   String
  memory     Memory    @relation(fields: [memoryId], references: [id])
  conflictId String?   @unique
  conflict   Conflict? @relation(fields: [conflictId], references: [id])
  type       String    // new_memory | conflict
  title      String
  status     String    @default("pending") // pending | approved | rejected
  resolvedAt DateTime?
  note       String?
  createdAt  DateTime  @default(now())

  @@index([status])
}

model SyncRun {
  id                  String    @id @default(cuid())
  sourceId            String
  source              Source    @relation(fields: [sourceId], references: [id])
  trigger             String    // manual | upload | fs_watch
  status              String    @default("running") // running | completed | failed
  conversationsParsed Int       @default(0)
  memoriesExtracted   Int       @default(0)
  conflictsFound      Int       @default(0)
  reviewItemsCreated  Int       @default(0)
  tokensUsed          Int       @default(0)
  errorMessage        String?
  durationMs          Int?
  startedAt           DateTime  @default(now())
  completedAt         DateTime?
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  summary   String
  details   String   @default("{}")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model ExportLog {
  id            String   @id @default(cuid())
  destination   String   // poke | claude_code | chatgpt | json
  status        String   // success | failed | dry_run
  memoriesCount Int
  errorMessage  String?
  details       String   @default("{}")
  durationMs    Int?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([destination])
}

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  color     String   @default("bg-neutral-100 text-neutral-600")
  sortOrder Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Folder {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  parentId  String?
  parent    Folder?   @relation("FolderTree", fields: [parentId], references: [id])
  children  Folder[]  @relation("FolderTree")
  icon      String?
  color     String?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  memories  MemoryFolder[]
}

model MemoryFolder {
  id        String   @id @default(cuid())
  memoryId  String
  memory    Memory   @relation(fields: [memoryId], references: [id])
  folderId  String
  folder    Folder   @relation(fields: [folderId], references: [id])
  createdAt DateTime @default(now())

  @@unique([memoryId, folderId])
  @@index([memoryId])
  @@index([folderId])
}
